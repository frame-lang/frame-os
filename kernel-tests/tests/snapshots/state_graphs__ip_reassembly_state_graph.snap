            </font></td></tr>
        </table>
    > margin=0 shape=none]
    Reassembling [label = <
        <table CELLBORDER="0" CELLPADDING="5" style="rounded">
            <tr><td><b>Reassembling</b></td></tr>
            <hr/>
            <tr><td align="left"><font point-size="10">
$&gt;()<br ALIGN="LEFT"/>fragment(frag: crate::ip_reasm::Fragment)<br ALIGN="LEFT"/>timeout()<br ALIGN="LEFT"/>state()<br ALIGN="LEFT"/>
            </font></td></tr>
